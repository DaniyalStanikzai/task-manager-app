<%- include('../partials/header') %>
<div class="page-header">
  <h1>My Projects</h1>
  <a href="/projects/new" class="btn btn-primary">+ New Project</a>
</div>

<% if (projects.length === 0) { %>
  <p class="empty-state">No projects yet. <a href="/projects/new">Create one!</a></p>
<% } else { %>
  <div class="card-grid">
    <% projects.forEach(project => { %>
      <a href="/projects/<%= project.id %>" class="project-card" style="border-top: 4px solid <%= project.color %>">
        <h3><%= project.title %></h3>
        <p><%= project.description || 'No description' %></p>
      </a>
    <% }) %>
  </div>
<% } %>
<%- include('../partials/footer') %>
